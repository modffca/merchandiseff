// api/proxy.js — Vercel Serverless Function
// Proxies requests to Google Apps Script to avoid CORS issues

const APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbye8KOyKjzVmqTeEJWENdcfemRSNDPIcho1JzX02Gh2_lQhgmL4JnLbAuHLfg_udAT5/exec';

export default async function handler(req, res) {
  // Allow all origins (safe because we control the Apps Script)
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'GET, POST, OPTIONS');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type');

  // Handle preflight
  if (req.method === 'OPTIONS') {
    return res.status(200).end();
  }

  try {
    let response;

    if (req.method === 'GET') {
      const action = req.query.action || '';
      const url = `${APPS_SCRIPT_URL}?action=${action}`;
      response = await fetch(url, { redirect: 'follow' });

    } else if (req.method === 'POST') {
      response = await fetch(APPS_SCRIPT_URL, {
        method: 'POST',
        redirect: 'follow',
        headers: { 'Content-Type': 'text/plain;charset=utf-8' },
        body: JSON.stringify(req.body),
      });

    } else {
      return res.status(405).json({ success: false, message: 'Method not allowed' });
    }

    const text = await response.text();

    // Try to parse as JSON, fallback to raw text
    try {
      const json = JSON.parse(text);
      return res.status(200).json(json);
    } catch {
      return res.status(200).send(text);
    }

  } catch (err) {
    return res.status(500).json({ success: false, message: 'Proxy error: ' + err.message });
  }
}
